# Copy this file to ".env" (same folder) and fill in real values.
# Never commit the real ".env" file — it holds secrets.

# ── Required ──────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=

# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telethon "userbot" login string. Get this by running the bot once and
# sending it /gensession, then paste the string it gives you back here.
# Leave blank for the very first run — you can't generate it until the
# bot is already running with BOT_TOKEN set.
SESSION_STRING=

# ── Optional ──────────────────────────────────────────────────────────────
# Your own Telegram numeric user ID. Without this the bot is open to
# anyone who finds it. Find your ID by messaging @userinfobot.
ADMIN_ID=

# Pre-fill source/destination channels (or set later with /setsource, /setdest)
SOURCE_CHANNEL=
DEST_CHANNEL=

# Second Telethon account, enables the "dual copy" speed-up feature
SESSION_STRING_2=

# Caption tweaks
CAPTION_REPLACE=
CAPTION_SUFFIX=
NOTIFY_EVERY=100
ALLOWED_EXTS=
SKIP_TEXT=false

# Where persistent data (dedup db, checkpoints, session flags) is stored.
# Leave as /app/data when running via Docker (matches the volume mount
# in docker-compose.yml). Only change this if you know what you're doing.
DATA_DIR=/app/data

# Port for the built-in health check server (Docker/Compose already expects 8080)
PORT=8080
